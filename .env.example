# ==================== SERVER CONFIGURATION ====================
NODE_ENV=development
PORT=5000

# ==================== DATABASE ====================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ==================== JWT & AUTHENTICATION ====================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRE=30d

# Admin credentials
ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=OptionalStrongPassword

# ==================== CSRF PROTECTION ====================
CSRF_SECRET=your-csrf-secret-key-min-32-chars

# ==================== CORS ====================
# In production, set these to your deployed frontend URLs
# FRONTEND_URL is automatically added to allowed origins
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed origins (include Vercel + Render URLs in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== FILE UPLOADS ====================
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
MAX_IMAGE_DIMENSION=2000

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com

# ==================== PAYMENT GATEWAYS ====================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== FRONTEND ====================
VITE_API_URL=http://localhost:5000/api
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxx

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_DIR=./logs

# ==================== SESSION & COOKIES ====================
SESSION_SECRET=your-session-secret-key
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ==================== SECURITY ====================
CSP_ENABLED=true
HSTS_ENABLED=false

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
ORDER_RATE_LIMIT_MAX=10

# ==================== FEATURE FLAGS ====================
ENABLE_NEWSLETTER=true
ENABLE_TESTIMONIALS=true
ENABLE_WISHLIST=true
ENABLE_PAYMENT_GATEWAY=true

# ==================== MAINTENANCE ====================
MAINTENANCE_MODE=false
{
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "outputDirectory": "dist/client",
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/"
        },
        {
            "handle": "filesystem"
        }
    ]
}